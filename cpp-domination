                <h2 class="text-3xl md:text-5xl font-bold text-white mb-4">C++ Arcade: Compilateur Suprême</h2>
                <p class="text-gray-400 max-w-2xl mx-auto">
                    Pilotez le vaisseau C++. Tirez des <strong>pointeurs laser</strong> pour désintégrer les bugs et les langages inférieurs avant qu'ils ne ralentissent le système !
                </p>
            </div>

            <!-- Game Board Container -->
            <div class="bg-cppgray border-2 border-gray-800 rounded-2xl overflow-hidden p-6 shadow-2xl relative">
                
                <!-- Instructions / HUD Overlay -->
                <div class="flex flex-col sm:flex-row justify-between items-center mb-4 gap-4 font-mono">
                    <div class="flex items-center gap-6">
                        <div class="text-gray-400">SCORE: <span id="score-val" class="text-cppcyan font-bold text-lg">0</span></div>
                        <div class="text-gray-400">SYSTÈME RAM: <span id="ram-val" class="text-emerald-400 font-bold text-lg">100%</span></div>
                    </div>
                    <div class="text-xs text-gray-500 flex items-center gap-2">
                        <span><span class="bg-gray-800 px-1.5 py-0.5 rounded text-white font-bold">&larr; / &rarr;</span> ou <span class="bg-gray-800 px-1.5 py-0.5 rounded text-white font-bold">Toucher</span> pour bouger</span>
                        <span><span class="bg-gray-800 px-1.5 py-0.5 rounded text-white font-bold">ESPACE</span> pour tirer</span>
                    </div>
                </div>

                <!-- Actual Canvas -->
                <div class="relative w-full aspect-[16/9] max-h-[480px] bg-cppdark rounded-lg overflow-hidden border border-gray-800">
                    <canvas id="game-canvas" class="w-full h-full block"></canvas>
                    
                    <!-- Game Over screen / Start Screen -->
                    <div id="game-overlay" class="absolute inset-0 bg-cppdark/95 flex flex-col items-center justify-center text-center p-6 transition-all duration-300">
                        <div class="mb-6">
                            <div class="w-16 h-16 bg-gradient-to-br from-cppblue to-cppcyan rounded-2xl flex items-center justify-center font-mono font-bold text-white text-3xl mx-auto shadow-lg shadow-cppblue/50 animate-bounce mb-4">
                                C++
                            </div>
                            <h3 id="overlay-title" class="text-2xl md:text-3xl font-bold text-white font-mono mb-2">C++ Compiler Strike</h3>
                            <p id="overlay-text" class="text-gray-400 text-sm max-w-sm mx-auto mb-6">
                                Détruisez JS, Rust, Ruby, et Lua pour prouver la suprématie du C++.
                            </p>
                        </div>
                        <button id="start-btn" class="px-8 py-3 bg-gradient-to-r from-cppblue to-cppcyan hover:from-cppcyan hover:to-cppblue text-white font-mono font-bold rounded-lg transition-transform hover:scale-105 active:scale-95 shadow-md">
                            DÉMARRER LA COMPILATION (PLAY)
                        </button>
                    </div>
                </div>

                <!-- Game Touch Controls (visible on touch devices) -->
                <div class="flex justify-between items-center mt-4 md:hidden">
                    <div class="flex gap-2">
                        <button id="touch-left" class="w-16 h-16 bg-gray-800 text-white rounded-lg flex items-center justify-center text-2xl active:bg-cppblue"><i data-lucide="arrow-left"></i></button>
                        <button id="touch-right" class="w-16 h-16 bg-gray-800 text-white rounded-lg flex items-center justify-center text-2xl active:bg-cppblue"><i data-lucide="arrow-right"></i></button>
                    </div>
                    <button id="touch-shoot" class="w-24 h-16 bg-gradient-to-r from-rose-500 to-red-600 text-white rounded-lg font-mono font-bold text-sm active:from-red-600 active:to-rose-500">TIRER</button>
                </div>

            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="py-12 px-6 border-t border-gray-900 bg-cppdark">
        <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
            <div class="flex items-center space-x-3">
                <div class="w-8 h-8 bg-cppblue rounded flex items-center justify-center font-mono font-bold text-white">
                    ++
                </div>
                <span class="font-mono text-gray-500 text-sm">std::cout &lt;&lt; "Fait par des passionnés du métal." &lt;&lt; std::endl;</span>
            </div>
            <div class="text-gray-600 text-xs font-mono">
                &copy; 2026 C++ Overlord. Aucune garbage collection n'a été maltraitée durant la création de ce site.
            </div>
        </div>
    </footer>

    <!-- Game & Page Logic Script -->
    <script>
        // Init Lucide icons
        lucide.createIcons();

        // Responsive Mobile Menu
        const menuBtn = document.getElementById('menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        menuBtn.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
        });

        // ------------------ GAME ENGINE ------------------
        const canvas = document.getElementById('game-canvas');
        const ctx = canvas.getContext('2d');
        const overlay = document.getElementById('game-overlay');
        const startBtn = document.getElementById('start-btn');
        const overlayTitle = document.getElementById('overlay-title');
        const overlayText = document.getElementById('overlay-text');
        
        const scoreVal = document.getElementById('score-val');
        const ramVal = document.getElementById('ram-val');

        // Touch buttons
        const btnLeft = document.getElementById('touch-left');
        const btnRight = document.getElementById('touch-right');
        const btnShoot = document.getElementById('touch-shoot');

        // Setup dynamic canvas size
        function resizeCanvas() {
            // Get parent container width
            const rect = canvas.parentNode.getBoundingClientRect();
            canvas.width = rect.width;
            canvas.height = rect.height;
        }
        window.addEventListener('resize', resizeCanvas);
        resizeCanvas();

        let gameActive = false;
        let score = 0;
        let ram = 100;
        let playerX = 0;
        const playerWidth = 60;
        const playerHeight = 40;
        let bullets = [];
        let enemies = [];
        let keys = {};
        let spawnTimer = 0;
        let touchMoveDir = 0; // -1 for left, 1 for right, 0 for none

        // Enemy language dictionary with logos/colors
        const langTypes = [
            { name: "JS", color: "#F7DF1E", text: "JS", speed: 2, points: 10, quote: "Undefined is not a function!" },
            { name: "Ruby", color: "#E0115F", text: "Ruby", speed: 1.5, points: 15, quote: "Trop lent !" },
            { name: "Rust", color: "#CE412B", text: "Rust", speed: 2.2, points: 25, quote: "Borrow check !" },
            { name: "Lua", color: "#000080", text: "Lua", speed: 3, points: 20, quote: "Table overflow !" }
        ];

        // Controls setup
        window.addEventListener('keydown', (e) => {
            keys[e.code] = true;
            if (e.code === "Space" && gameActive) {
                shootBullet();
                e.preventDefault();
            }
        });
        window.addEventListener('keyup', (e) => {
            keys[e.code] = false;
        });

        // Touch control handlers
        btnLeft.addEventListener('touchstart', (e) => { e.preventDefault(); touchMoveDir = -1; });
        btnLeft.addEventListener('touchend', () => { touchMoveDir = 0; });
        btnRight.addEventListener('touchstart', (e) => { e.preventDefault(); touchMoveDir = 1; });
        btnRight.addEventListener('touchend', () => { touchMoveDir = 0; });
        btnShoot.addEventListener('touchstart', (e) => {
            e.preventDefault();
            if (gameActive) shootBullet();
        });

        function initGame() {
            score = 0;
            ram = 100;
            playerX = canvas.width / 2 - playerWidth / 2;
            bullets = [];
            enemies = [];
            scoreVal.innerText = score;
            ramVal.innerText = ram + "%";
            ramVal.className = "text-emerald-400 font-bold text-lg";
            spawnTimer = 0;
        }

        function shootBullet() {
            // Cool-down check
            if (bullets.length > 10) return; 
            bullets.push({
                x: playerX + playerWidth / 2 - 3,
                y: canvas.height - playerHeight - 15,
                width: 6,
                height: 15,
                speed: 8
            });
        }

        function spawnEnemy() {
            const type = langTypes[Math.floor(Math.random() * langTypes.length)];
            const width = 50;
            const height = 30;
            const x = Math.random() * (canvas.width - width);
            enemies.push({
                x: x,
                y: -height,
                width: width,
                height: height,
                type: type,
                speed: type.speed + (score / 150) // Scale speed slowly with score
            });
        }

        function checkCollision(rect1, rect2) {
            return rect1.x < rect2.x + rect2.width &&
                   rect1.x + rect1.width > rect2.x &&
                   rect1.y < rect2.y + rect2.height &&
                   rect1.y + rect1.height > rect2.y;
        }

        function update() {
            if (!gameActive) return;

            // Player movement
            const speed = 7;
            if (keys["ArrowLeft"] || touchMoveDir === -1) {
                playerX = Math.max(0, playerX - speed);
            }
            if (keys["ArrowRight"] || touchMoveDir === 1) {
                playerX = Math.min(canvas.width - playerWidth, playerX + speed);
            }

            // Move bullets
            bullets.forEach((b, index) => {
                b.y -= b.speed;
                if (b.y < 0) {
                    bullets.splice(index, 1);
                }
            });

            // Enemy Spawner
            spawnTimer++;
            const currentSpawnRate = Math.max(25, 60 - Math.floor(score / 5));
            if (spawnTimer >= currentSpawnRate) {
                spawnEnemy();
                spawnTimer = 0;
            }

            // Move enemies
            enemies.forEach((e, index) => {
                e.y += e.speed;
                
                // Reach bottom -> decrease RAM health
                if (e.y > canvas.height) {
                    enemies.splice(index, 1);
                    ram -= 15;
                    if (ram <= 0) {
                        ram = 0;
                        endGame();
                    }
                    updateHUD();
                    return;
                }

                // Check collision with bullets
                bullets.forEach((b, bIndex) => {
                    if (checkCollision(b, e)) {
                        bullets.splice(bIndex, 1);
                        createExplosionEffect(e.x + e.width/2, e.y + e.height/2, e.type.color);
                        enemies.splice(index, 1);
                        score += e.type.points;
                        updateHUD();
                    }
                });
            });
        }

        // Particle FX system for sweet modern feel
        let particles = [];
        function createExplosionEffect(x, y, color) {
            for(let i=0; i<8; i++) {
                particles.push({
                    x: x,
                    y: y,
                    vx: (Math.random() - 0.5) * 6,
                    vy: (Math.random() - 0.5) * 6,
                    radius: Math.random() * 3 + 2,
                    alpha: 1,
                    color: color
                });
            }
        }

        function updateAndDrawParticles() {
            particles.forEach((p, idx) => {
                p.x += p.vx;
                p.y += p.vy;
                p.alpha -= 0.04;
                if(p.alpha <= 0) {
                    particles.splice(idx, 1);
                    return;
                }
                ctx.save();
                ctx.globalAlpha = p.alpha;
                ctx.fillStyle = p.color;
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
                ctx.fill();
                ctx.restore();
            });
        }

        function updateHUD() {
            scoreVal.innerText = score;
            ramVal.innerText = ram + "%";
            if (ram < 40) {
                ramVal.className = "text-rose-500 font-bold text-lg animate-pulse";
            } else if (ram < 70) {
                ramVal.className = "text-yellow-500 font-bold text-lg";
            } else {
                ramVal.className = "text-emerald-400 font-bold text-lg";
            }
        }

        function draw() {
            // Clear screen
            ctx.fillStyle = "#0D1117";
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            // Draw cyber grid background inside game
            ctx.strokeStyle = "#161B22";
            ctx.lineWidth = 1;
            const gridSize = 40;
            for(let x=0; x<canvas.width; x+=gridSize) {
                ctx.beginPath();
                ctx.moveTo(x, 0);
                ctx.lineTo(x, canvas.height);
                ctx.stroke();
            }
            for(let y=0; y<canvas.height; y+=gridSize) {
                ctx.beginPath();
                ctx.moveTo(0, y);
                ctx.lineTo(canvas.width, y);
                ctx.stroke();
            }

            // Draw player ship: styled as futuristic C++ logo / shield
            const py = canvas.height - playerHeight - 10;
            ctx.fillStyle = "#00599C";
            ctx.beginPath();
            ctx.moveTo(playerX, py + playerHeight);
            ctx.lineTo(playerX + playerWidth / 2, py);
            ctx.lineTo(playerX + playerWidth, py + playerHeight);
            ctx.closePath();
            ctx.fill();

            // Inner styling for the C++ Ship
            ctx.fillStyle = "#00B4D8";
            ctx.beginPath();
            ctx.moveTo(playerX + 15, py + playerHeight - 5);
            ctx.lineTo(playerX + playerWidth / 2, py + 12);
            ctx.lineTo(playerX + playerWidth - 15, py + playerHeight - 5);
            ctx.closePath();
            ctx.fill();

            // Text "C++" inside the player
            ctx.fillStyle = "#FFFFFF";
            ctx.font = "bold 12px 'Fira Code', monospace";
            ctx.fillText("C++", playerX + playerWidth / 2 - 10, py + playerHeight - 8);

            // Draw bullets
            ctx.fillStyle = "#00B4D8";
            bullets.forEach(b => {
                ctx.shadowBlur = 10;
                ctx.shadowColor = "#00B4D8";
                ctx.fillRect(b.x, b.y, b.width, b.height);
                ctx.shadowBlur = 0; // reset
            });

            // Draw enemies (inferior languages)
            enemies.forEach(e => {
                ctx.fillStyle = e.type.color;
                // Draw code block / rectangle
                ctx.beginPath();
                ctx.roundRect(e.x, e.y, e.width, e.height, 6);
                ctx.fill();

                // Draw text logo on the enemy box
                ctx.fillStyle = "#FFFFFF";
                if (e.type.name === "JS") ctx.fillStyle = "#000000"; // JS looks better with dark text
                ctx.font = "bold 12px 'Fira Code', monospace";
                ctx.textAlign = "center";
                ctx.fillText(e.type.text, e.x + e.width / 2, e.y + e.height / 2 + 4);
                ctx.textAlign = "left"; // Reset alignment
            });

            // Particles
            updateAndDrawParticles();
        }

        function gameLoop() {
            update();
            draw();
            if (gameActive) {
                requestAnimationFrame(gameLoop);
            }
        }

        function endGame() {
            gameActive = false;
            overlayTitle.innerText = "Compilation interrompue !";
            overlayText.innerHTML = `La RAM a saturé sous le poids des langages inefficaces.<br/><span class="text-white font-bold">Votre Score : ${score}</span>`;
            startBtn.innerText = "RECOMPILER LE CODE (REPLAY)";
            overlay.classList.remove('opacity-0', 'pointer-events-none');
        }

        // Start button trigger
        startBtn.addEventListener('click', () => {
            overlay.classList.add('opacity-0', 'pointer-events-none');
            initGame();
            gameActive = true;
            gameLoop();
        });

    </script>
</body>
</html>
